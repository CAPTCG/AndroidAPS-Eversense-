+
+    @Test
+    fun `uploadGlucoseReadings sends correct JSON body fields`() {
+        val futureExpiry = System.currentTimeMillis() + 600_000L
+        whenever(prefs.getLong(StorageKeys.ACCESS_TOKEN_EXPIRY, 0)).thenReturn(futureExpiry)
