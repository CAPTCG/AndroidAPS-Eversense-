From fcd4e42aeef3ab9aee10f7d1e61c35cfe23490a9 Mon Sep 17 00:00:00 2001
From: Craig Gordon <craighvac@gmail.com>
Date: Mon, 20 Apr 2026 09:26:41 +0000
Subject: [PATCH] Add Eversense transmitter battery % to Overview status lights

---
 .../src/main/kotlin/app/aaps/plugins/source/EversensePlugin.kt | 3 +++
 .../aaps/ui/compose/overview/statusLights/StatusViewModel.kt   | 2 +-
 2 files changed, 4 insertions(+), 1 deletion(-)

diff --git a/plugins/source/src/main/kotlin/app/aaps/plugins/source/EversensePlugin.kt b/plugins/source/src/main/kotlin/app/aaps/plugins/source/EversensePlugin.kt
index 35b24eab8b..8879fe26b6 100644
--- a/plugins/source/src/main/kotlin/app/aaps/plugins/source/EversensePlugin.kt
+++ b/plugins/source/src/main/kotlin/app/aaps/plugins/source/EversensePlugin.kt
@@ -84,6 +84,7 @@ class EversensePlugin @Inject constructor(
 
     @Inject lateinit var persistenceLayer: PersistenceLayer
 
+    override var sensorBatteryLevel = -1
 
     private val mainHandler = Handler(Looper.getMainLooper())
     private val ioScope = CoroutineScope(SupervisorJob() + Dispatchers.IO)
@@ -227,6 +228,8 @@ class EversensePlugin @Inject constructor(
     override fun onStateChanged(state: EversenseState) {
         aapsLogger.info(LTag.BGSOURCE, "New state received: ${Json.encodeToString(state)}")
 
+        // Update sensor battery level for Overview status lights
+        sensorBatteryLevel = if (state.batteryPercentage > 0) state.batteryPercentage else -1
 
         // Sync SAGE color thresholds to match Eversense sensor lifetime and notification days
         if (state.insertionDate > 0) {
diff --git a/ui/src/main/kotlin/app/aaps/ui/compose/overview/statusLights/StatusViewModel.kt b/ui/src/main/kotlin/app/aaps/ui/compose/overview/statusLights/StatusViewModel.kt
index c11d38df16..c19aab6289 100644
--- a/ui/src/main/kotlin/app/aaps/ui/compose/overview/statusLights/StatusViewModel.kt
+++ b/ui/src/main/kotlin/app/aaps/ui/compose/overview/statusLights/StatusViewModel.kt
@@ -137,7 +137,7 @@ class StatusViewModel @Inject constructor(
             levelStatus = if (levelPercent >= 0) getLevelStatus((levelPercent * 100).toDouble(), IntKey.OverviewSbatWarning, IntKey.OverviewSbatCritical) else StatusLevel.UNSPECIFIED,
             levelPercent = if (levelPercent >= 0) 1f - levelPercent else -1f,
             icon = IcCgmInsert,
-            compactLevel = false // Overview: sensor battery not shown
+            compactLevel = true // Overview: show sensor battery
         )
     }
 
-- 
2.43.0

