+        strength >= 75 -> "Excellent"
+        strength >= 48 -> "Good"
+        strength >= 30 -> "Low"
+        strength >= 25 -> "Poor"
+        strength > 0   -> "Very Poor"
+        else           -> rh.gs(R.string.eversense_not_connected)
