+    RateAlert(0x0000_1010),
+    RateFallingAlert(0x0000_1025),
+    RateRisingAlert(0x0000_1026),
+    RateFallingThreshold(0x0000_1011),
+    RateRisingThreshold(0x0000_1012),
+    SensorFieldCurrentRaw(0x0000_0874),
