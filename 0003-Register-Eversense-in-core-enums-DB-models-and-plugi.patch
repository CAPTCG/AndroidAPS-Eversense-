From 04818f36232fdece910488e785a96bde372c0d6d Mon Sep 17 00:00:00 2001
From: Craig Gordon <craighvac@gmail.com>
Date: Mon, 4 May 2026 08:46:09 -0400
Subject: [PATCH 3/5] Register Eversense in core enums, DB models, and plugin
 list

- Add EVERSENSE_E3 and EVERSENSE_365 to SourceSensor enum
- Add Eversense notification IDs to NotificationId
- Update GlucoseValue and DB converter for new sensor types
- Wire Eversense module in PluginsListModule, MainApp, settings.gradle
---
 app/src/main/kotlin/app/aaps/MainApp.kt                   | 3 +++
 app/src/main/kotlin/app/aaps/di/PluginsListModule.kt      | 8 +++++++-
 .../main/kotlin/app/aaps/core/data/model/SourceSensor.kt  | 2 ++
 .../app/aaps/core/data/model/SourceSensorExtensions.kt    | 2 ++
 .../aaps/core/data/model/SourceSensorExtensionsTest.kt    | 8 +++++++-
 .../aaps/core/interfaces/notifications/NotificationId.kt  | 4 ++++
 .../kotlin/app/aaps/database/entities/GlucoseValue.kt     | 2 ++
 .../persistence/converters/SourceSensorExtension.kt       | 4 ++++
 settings.gradle                                           | 1 +
 9 files changed, 32 insertions(+), 2 deletions(-)

diff --git a/app/src/main/kotlin/app/aaps/MainApp.kt b/app/src/main/kotlin/app/aaps/MainApp.kt
index f8ec693901..4736ef9218 100644
--- a/app/src/main/kotlin/app/aaps/MainApp.kt
+++ b/app/src/main/kotlin/app/aaps/MainApp.kt
@@ -445,6 +445,9 @@ class MainApp : Application(), HasAndroidInjector {
         }
         // Clear SmsOtpPassword if wrongly replaced
         if (preferences.get(StringKey.SmsOtpPassword).length > 10) preferences.put(StringKey.SmsOtpPassword, "")
+        // Raise sensor battery thresholds from old defaults (25/5) to new defaults (40/20)
+        if (preferences.get(IntKey.OverviewSbatWarning) == 25) preferences.put(IntKey.OverviewSbatWarning, 40)
+        if (preferences.get(IntKey.OverviewSbatCritical) == 5) preferences.put(IntKey.OverviewSbatCritical, 20)
 
         val keys: Map<String, *> = sp.getAll()
         // Migrate ActivityMonitor
